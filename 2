#include <stdio.h>
#include <string.h>

void trim_newline(char *str);
void encode_char(char c, char out[3]);
int decode_char(char h1, char h2, char *out);
int hex_to_int(char c);
int validate_encode_input(const char *str);
int validate_decode_input(const char *str);

int main(void) {
    char mode_line[16];
    char input[4096];
    int mode = -1;

    if (fgets(mode_line, sizeof(mode_line), stdin) == NULL) {
        printf("n/a\n");
        return 0;
    }

    trim_newline(mode_line);

    if (strcmp(mode_line, "0") == 0) {
        mode = 0;
    } else if (strcmp(mode_line, "1") == 0) {
        mode = 1;
    } else {
        printf("n/a\n");
        return 0;
    }

    if (fgets(input, sizeof(input), stdin) == NULL) {
        printf("n/a\n");
        return 0;
    }

    trim_newline(input);

    if (mode == 0) {
        if (!validate_encode_input(input)) {
            printf("n/a\n");
            return 0;
        }

        for (int i = 0; input[i] != '\0'; i += 2) {
            char code[3];
            encode_char(input[i], code);
            printf("%s", code);
            if (input[i + 2] != '\0') {
                printf(" ");
            }
        }
        printf("\n");
    } else {
        if (!validate_decode_input(input)) {
            printf("n/a\n");
            return 0;
        }

        for (int i = 0; input[i] != '\0'; i += 3) {
            char result;
            if (!decode_char(input[i], input[i + 1], &result)) {
                printf("n/a\n");
                return 0;
            }
            printf("%c", result);
            if (input[i + 3] != '\0') {
                printf(" ");
            }
        }
        printf("\n");
    }

    return 0;
}

void trim_newline(char *str) {
    int len = strlen(str);
    while (len > 0 && (str[len - 1] == '\n' || str[len - 1] == '\r')) {
        str[len - 1] = '\0';
        len--;
    }
}

void encode_char(char c, char out[3]) {
    const char hex[] = "0123456789ABCDEF";
    unsigned char uc = (unsigned char)c;
    out[0] = hex[uc / 16];
    out[1] = hex[uc % 16];
    out[2] = '\0';
}

int decode_char(char h1, char h2, char *out) {
    int high = hex_to_int(h1);
    int low = hex_to_int(h2);

    if (high == -1 || low == -1) {
        return 0;
    }

    *out = (char)(high * 16 + low);
    return 1;
}

int hex_to_int(char c) {
    if (c >= '0' && c <= '9') {
        return c - '0';
    }
    if (c >= 'A' && c <= 'F') {
        return c - 'A' + 10;
    }
    if (c >= 'a' && c <= 'f') {
        return c - 'a' + 10;
    }
    return -1;
}

int validate_encode_input(const char *str) {
    int len = strlen(str);

    if (len == 0 || len % 2 == 0) {
        return 0;
    }

    for (int i = 0; i < len; i++) {
        if (i % 2 == 0) {
            if (str[i] == ' ') {
                return 0;
            }
        } else {
            if (str[i] != ' ') {
                return 0;
            }
        }
    }

    return 1;
}

int validate_decode_input(const char *str) {
    int len = strlen(str);

    if (len == 0 || (len + 1) % 3 != 0) {
        return 0;
    }

    for (int i = 0; i < len; i++) {
        if ((i + 1) % 3 == 0) {
            if (str[i] != ' ') {
                return 0;
            }
        } else {
            if (hex_to_int(str[i]) == -1) {
                return 0;
            }
        }
    }

    return 1;
}
