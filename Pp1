#include <stdio.h>

#define WIDTH 80
#define HEIGHT 25
#define PADDLE_SIZE 3
#define WIN_SCORE 21

#define LEFT_PADDLE_X 2
#define RIGHT_PADDLE_X (WIDTH - 3)

void clear_screen(void);
void draw_field(int left_paddle_y, int right_paddle_y, int ball_x, int ball_y,
                int left_score, int right_score);
int read_command(void);
void move_paddle(int command, int *left_paddle_y, int *right_paddle_y);
void reset_round(int *left_paddle_y, int *right_paddle_y, int *ball_x, int *ball_y,
                 int *ball_dx, int *ball_dy, int start_dx);
void update_ball(int left_paddle_y, int right_paddle_y, int *ball_x, int *ball_y,
                 int *ball_dx, int *ball_dy, int *left_score, int *right_score);

int main(void) {
    int left_paddle_y;
    int right_paddle_y;
    int ball_x;
    int ball_y;
    int ball_dx;
    int ball_dy;
    int left_score = 0;
    int right_score = 0;
    int command;

    reset_round(&left_paddle_y, &right_paddle_y, &ball_x, &ball_y, &ball_dx, &ball_dy, -1);
    draw_field(left_paddle_y, right_paddle_y, ball_x, ball_y, left_score, right_score);

    while (left_score < WIN_SCORE && right_score < WIN_SCORE) {
        command = read_command();
        if (command == EOF) {
            break;
        }

        move_paddle(command, &left_paddle_y, &right_paddle_y);
        update_ball(left_paddle_y, right_paddle_y, &ball_x, &ball_y,
                    &ball_dx, &ball_dy, &left_score, &right_score);
        draw_field(left_paddle_y, right_paddle_y, ball_x, ball_y, left_score, right_score);
    }

    if (left_score >= WIN_SCORE) {
        printf("Player 1 wins!\n");
    } else if (right_score >= WIN_SCORE) {
        printf("Player 2 wins!\n");
    }

    return 0;
}

void clear_screen(void) {
    int i;
    for (i = 0; i < 30; i++) {
        putchar('\n');
    }
}

void draw_field(int left_paddle_y, int right_paddle_y, int ball_x, int ball_y,
                int left_score, int right_score) {
    int x, y;

    clear_screen();
    printf("Score: %d : %d\n", left_score, right_score);

    for (y = 0; y < HEIGHT; y++) {
        for (x = 0; x < WIDTH; x++) {
            if (y == 0 || y == HEIGHT - 1) {
                putchar('-');
            } else if (x == 0 || x == WIDTH - 1) {
                putchar('|');
            } else if (x == ball_x && y == ball_y) {
                putchar('o');
            } else if (x == LEFT_PADDLE_X &&
                       y >= left_paddle_y - 1 && y <= left_paddle_y + 1) {
                putchar('|');
            } else if (x == RIGHT_PADDLE_X &&
                       y >= right_paddle_y - 1 && y <= right_paddle_y + 1) {
                putchar('|');
            } else {
                putchar(' ');
            }
        }
        putchar('\n');
    }
}

int read_command(void) {
    int c;

    while ((c = getchar()) != EOF) {
        if (c == '\n' || c == '\r') {
            continue;
        }

        if (c == 'a' || c == 'A' ||
            c == 'z' || c == 'Z' ||
            c == 'k' || c == 'K' ||
            c == 'm' || c == 'M' ||
            c == ' ') {
            return c;
        }
    }

    return EOF;
}

void move_paddle(int command, int *left_paddle_y, int *right_paddle_y) {
    if ((command == 'a' || command == 'A') && *left_paddle_y > 2) {
        (*left_paddle_y)--;
    } else if ((command == 'z' || command == 'Z') && *left_paddle_y < HEIGHT - 3) {
        (*left_paddle_y)++;
    } else if ((command == 'k' || command == 'K') && *right_paddle_y > 2) {
        (*right_paddle_y)--;
    } else if ((command == 'm' || command == 'M') && *right_paddle_y < HEIGHT - 3) {
        (*right_paddle_y)++;
    }
}

void reset_round(int *left_paddle_y, int *right_paddle_y, int *ball_x, int *ball_y,
                 int *ball_dx, int *ball_dy, int start_dx) {
    *left_paddle_y = HEIGHT / 2;
    *right_paddle_y = HEIGHT / 2;
    *ball_x = WIDTH / 2;
    *ball_y = HEIGHT / 2;
    *ball_dx = start_dx;
    *ball_dy = 1;
}

void update_ball(int left_paddle_y, int right_paddle_y, int *ball_x, int *ball_y,
                 int *ball_dx, int *ball_dy, int *left_score, int *right_score) {
    int next_x = *ball_x + *ball_dx;
    int next_y = *ball_y + *ball_dy;

    if (next_y == 0 || next_y == HEIGHT - 1) {
        *ball_dy = -(*ball_dy);
        next_y = *ball_y + *ball_dy;
    }

    if (next_x == LEFT_PADDLE_X && *ball_dx < 0 &&
        next_y >= left_paddle_y - 1 && next_y <= left_paddle_y + 1) {
        *ball_dx = -(*ball_dx);
        next_x = *ball_x + *ball_dx;
    } else if (next_x == RIGHT_PADDLE_X && *ball_dx > 0 &&
               next_y >= right_paddle_y - 1 && next_y <= right_paddle_y + 1) {
        *ball_dx = -(*ball_dx);
        next_x = *ball_x + *ball_dx;
    }

    if (next_x == 0) {
        (*right_score)++;
        reset_round(&left_paddle_y, &right_paddle_y, ball_x, ball_y, ball_dx, ball_dy, -1);
    } else if (next_x == WIDTH - 1) {
        (*left_score)++;
        reset_round(&left_paddle_y, &right_paddle_y, ball_x, ball_y, ball_dx, ball_dy, 1);
    } else {
        *ball_x = next_x;
        *ball_y = next_y;
    }
}
