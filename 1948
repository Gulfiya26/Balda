#include <stdio.h>

int my_abs(int x) {
    if (x < 0) return -x;
    return x;
}

int is_divisible(int a, int b) {
    if (b == 0) return 0;

    int dividend = my_abs(a);
    int divisor = my_abs(b);

    while (dividend >= divisor) {
        dividend -= divisor;
    }

    return (dividend == 0);
}

int is_prime(int n) {
    if (n <= 1) return 0;
    if (n == 2) return 1;
    if (is_divisible(n, 2)) return 0;

    for (int i = 3; i < n; i += 2) {
        if (is_divisible(n, i)) {
            return 0;
        }
    }
    return 1;
}

int find_largest_prime_factor(int a) {
    int num = my_abs(a);

    if (num <= 1) {
        return -1;
    }

    int largest = -1;

    for (int d = 2; d <= num; ++d) {
        if (is_divisible(num, d)) {
            if (is_prime(d)) {
                largest = d;
            }
        }
    }

    return largest;
}

int main() {
    int a;

    if (scanf("%d", &a) != 1) {
        putchar('n');
        putchar('/');
        putchar('a');
        return 0;
    }

    int result = find_largest_prime_factor(a);

    if (result == -1) {
        putchar('n');
        putchar('/');
        putchar('a');
    } else {
        printf("%d", result);
    }

    return 0;
}

