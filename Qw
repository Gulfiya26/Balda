#include <stdio.h>

// Объявления функций
void encode(char c);
void decode(char h1, char h2);
int validate_mode_0(const char *line);
int validate_mode_1(const char *line);
int is_hex(char c);

int main(int argc, char **argv) {
    // Проверка наличия аргумента командной строки
    if (argc != 2) {
        printf("n/a\n");
        return 0;
    }

    int mode = -1;
    // Проверка валидности аргумента (только '0' или '1')
    if (argv[1][0] == '0' && argv[1][1] == '\0') {
        mode = 0;
    } else if (argv[1][0] == '1' && argv[1][1] == '\0') {
        mode = 1;
    } else {
        printf("n/a\n");
        return 0;
    }

    // Буфер для чтения всей строки из stdin
    char line[2048];
    int i = 0;
    int ch;
    
    // Читаем поток до символа переноса строки (или EOF)
    while ((ch = getchar()) != '\n' && ch != EOF) {
        if (i < 2047) {
            line[i++] = ch;
        } else {
            // Защита от переполнения буфера
            printf("n/a\n");
            return 0;
        }
    }
    line[i] = '\0';

    // Если ввели пустую строку
    if (i == 0) {
        printf("n/a\n");
        return 0;
    }

    // Режим кодирования (Символ -> HEX)
    if (mode == 0) {
        if (validate_mode_0(line)) {
            for (int j = 0; j < i; j += 2) {
                encode(line[j]);
                // Если это не последний элемент, выводим пробел
                if (j + 2 < i) printf(" ");
            }
            printf("\n");
        } else {
            printf("n/a\n");
        }
    } 
    // Режим декодирования (HEX -> Символ)
    else {
        if (validate_mode_1(line)) {
            for (int j = 0; j < i; j += 3) {
                decode(line[j], line[j+1]);
                if (j + 3 < i) printf(" ");
            }
            printf("\n");
        } else {
            printf("n/a\n");
        }
    }

    return 0;
}

// Проверка формата для режима 0: "W O R L D"
int validate_mode_0(const char *line) {
    int len = 0;
    while (line[len]) len++;
    
    // Длина должна быть нечетной (символы и пробелы между ними)
    if (len == 0 || len % 2 == 0) return 0;
    
    for (int j = 0; j < len; j++) {
        // На нечетных индексах должны быть строго пробелы
        if (j % 2 == 1 && line[j] != ' ') return 0;
    }
    return 1;
}

// Проверка, является ли символ допустимым шестнадцатеричным числом
int is_hex(char c) {
    return (c >= '0' && c <= '9') || (c >= 'A' && c <= 'F') || (c >= 'a' && c <= 'f');
}

// Проверка формата для режима 1: "48 45 4C 4C 4F"
int validate_mode_1(const char *line) {
    int len = 0;
    while (line[len]) len++;
    
    // Формула длины для 2-значных токенов с 1 пробелом: (n*2) + (n-1) => (len + 1) % 3 == 0
    if (len == 0 || (len + 1) % 3 != 0) return 0;

    for (int j = 0; j < len; j++) {
        if ((j + 1) % 3 == 0) {
            // Каждый третий символ (индексы 2, 5, 8...) должен быть пробелом
            if (line[j] != ' ') return 0;
        } else {
            // Остальные должны быть шестнадцатеричными цифрами
            if (!is_hex(line[j])) return 0;
        }
    }
    return 1;
}

// Подзадача кодирования (Символ -> HEX)
void encode(char c) {
    printf("%02X", (unsigned char)c);
}

// Подзадача декодирования (HEX -> Символ)
void decode(char h1, char h2) {
    int val1, val2;
    
    // Конвертируем первый символ
    if (h1 >= '0' && h1 <= '9') val1 = h1 - '0';
    else if (h1 >= 'A' && h1 <= 'F') val1 = h1 - 'A' + 10;
    else if (h1 >= 'a' && h1 <= 'f') val1 = h1 - 'a' + 10;
    else val1 = 0;

    // Конвертируем второй символ
    if (h2 >= '0' && h2 <= '9') val2 = h2 - '0';
    else if (h2 >= 'A' && h2 <= 'F') val2 = h2 - 'A' + 10;
    else if (h2 >= 'a' && h2 <= 'f') val2 = h2 - 'a' + 10;
    else val2 = 0;

    // Собираем число (val1 * 16 + val2) и выводим как символ
    printf("%c", (char)(val1 * 16 + val2));
}
